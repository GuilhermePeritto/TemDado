{
  "manifest_version": 3,
  "name": "TemDado",
  "version": "1.0.0",
  "description": "Gera dados fictícios para cadastros de teste",
  "permissions": ["scripting", "activeTab"],
  "background": {
    "service_worker": "background.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "index.js", "index.css", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Tem Dado?",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
